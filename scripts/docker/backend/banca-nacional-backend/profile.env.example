# Variables de entorno para Docker backend (banca-nacional-backend)
# Copiar como dev.env, staging.env o prod.env según el perfil
# Las variables con prefijo ENV_ tienen prioridad sobre las variables directas

ENV_ACR_NAME=bancaacr
ENV_IMAGE_NAME=banca-backend
ENV_IMAGE_TAG=latest
ENV_JAVA_OPTS="-Xmx256m -Xms128m"
ENV_SPRING_PROFILES_ACTIVE=dev
ENV_REGISTRY_SERVER=
ENV_REGISTRY_USERNAME=
ENV_REGISTRY_PASSWORD=
