# Variables de entorno para impactar base de datos banca-nacional-backend
# Copiar como dev.env, staging.env o prod.env según el perfil
# Las variables con prefijo ENV_ tienen prioridad sobre las variables directas
#
# Obtener valores desde outputs de Terraform:
#   terraform output mysql_server_fqdn
#   terraform output mysql_admin_user
#   terraform output mysql_admin_password

# ---------------------------------------------------------------------------
# Conexión MySQL (Azure Flexible Server creado por Terraform)
# ---------------------------------------------------------------------------
ENV_MYSQL_HOSTNAME=
ENV_MYSQL_PORT=3306
ENV_MYSQL_USERNAME=banca_admin
ENV_MYSQL_PASSWORD=

# ---------------------------------------------------------------------------
# Ruta del script SQL a impactar (relativa a la raíz del proyecto)
# ---------------------------------------------------------------------------
ENV_SQL_SCRIPT=infra/database/banca-nacional-backend/banca_db_mysql57.sql

# ---------------------------------------------------------------------------
# Logging control
# ---------------------------------------------------------------------------
DEBUG_ENABLED=false
LOG_TO_FILE=false
