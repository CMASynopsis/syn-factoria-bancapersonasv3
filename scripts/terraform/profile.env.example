# =============================================================================
# profile.env.example — Azure Terraform profile configuration template
# =============================================================================
# Copy this file to <profile>.env (e.g., dev.env, staging.env, prod.env)
# and fill in the values for your environment.
#
# Azure authentication methods (choose ONE):
#   1. Azure CLI (az login) — no env vars needed, uses cached session
#   2. Service Principal — set ARM_CLIENT_ID + ARM_CLIENT_SECRET below
# =============================================================================

# ---------------------------------------------------------------------------
# Profile name (dev|staging|prod)
# Controls which .tfvars and backend-config HCL files are loaded.
# ---------------------------------------------------------------------------
TF_PROFILE=dev

# ---------------------------------------------------------------------------
# Azure authentication — Service Principal (optional if using az login)
# ---------------------------------------------------------------------------
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Azure location (default: eastus)
# Used by storage-account.sh create --profile <name>
# ---------------------------------------------------------------------------
LOCATION=eastus

# ---------------------------------------------------------------------------
# Logging control (from scripts/commons/log.sh)
# ---------------------------------------------------------------------------

# Enable DEBUG-level logs (default: false)
DEBUG_ENABLED=false

# Save logs to file under scripts/.logs/ (default: false)
LOG_TO_FILE=false

# ---------------------------------------------------------------------------
# Terraform backend — Azure Storage state storage (informational)
# These values are defined in infra/terraform/backend-configs/<profile>.hcl
# ---------------------------------------------------------------------------
TF_STATE_RG=banca-nacional-tfstate
TF_STATE_BUCKET=tfstatebancanacional
TF_STATE_CONTAINER=tfstate
TF_STATE_KEY=banca-nacional/terraform.tfstate
